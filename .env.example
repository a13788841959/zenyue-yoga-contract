# ─────────────────────────────────────────────────────────────────
# 禅悦国际瑜伽 · 电子合同系统 · 环境变量配置
# 复制本文件为 .env.local，填写真实值后启动项目
# ─────────────────────────────────────────────────────────────────

# Supabase PostgreSQL 连接串 (Prisma)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT].supabase.co:5432/postgres"

# Supabase 公开配置
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Supabase 服务端 Key（用于服务端文件上传，仅服务端使用）
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# 管理后台密码
ADMIN_PASSWORD="ZenYue@2025"

# 管理 Token Secret（32位随机字符串）
ADMIN_TOKEN_SECRET="your-32-char-random-secret-here!!"

# 应用域名（生产环境改为实际域名）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
